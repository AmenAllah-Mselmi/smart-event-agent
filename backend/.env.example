# Environment Configuration Template for Google Cloud Deployment
# Copy this file to .env and fill in your actual values

# Google Cloud Configuration
PROJECT_ID=your-project-id
GOOGLE_CLOUD_REGION=us-central1
SERVICE_ACCOUNT_EMAIL=smart-event-agent@your-project-id.iam.gserviceaccount.com

# API Keys (Store securely in Secret Manager, not in code!)
# These should be accessed from Google Cloud Secret Manager in production
GENAI_API_KEY=your_genai_api_key_here
GMAIL_API_KEY=your_gmail_api_key_here
MAPS_API_KEY=your_maps_api_key_here

# Firestore Configuration
FIRESTORE_DATABASE=default
FIRESTORE_COLLECTION_EVENTS=events
FIRESTORE_COLLECTION_USERS=users

# Pub/Sub Configuration
PUBSUB_TOPIC_ID=smart-event-events
PUBSUB_SUBSCRIPTION_ID=smart-event-events-subscription

# Frontend Configuration
FRONTEND_URL=https://smart-event-frontend-XXXXX.run.app
BACKEND_URL=https://smart-event-backend-XXXXX.run.app

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# CORS Settings
ALLOWED_ORIGINS=https://smart-event-frontend-XXXXX.run.app,https://your-domain.com

# Session Configuration
SESSION_SECRET=your-secure-session-secret-here

# Email Configuration (Gmail)
GMAIL_SENDER_EMAIL=your-service-account-email@gmail.com
GMAIL_SERVICE_ACCOUNT_FILE=/var/secrets/google/gmail-key.json

# Maps Configuration
MAPS_API_TIMEOUT=30
MAPS_CACHE_TTL=3600

# GenAI Configuration
GENAI_MODEL=gemini-pro
GENAI_MAX_TOKENS=2048
GENAI_TEMPERATURE=0.7

# Database
DATABASE_URL=firestore

# Timeouts and Limits
REQUEST_TIMEOUT=30
MAX_REQUEST_SIZE=10485760
RATE_LIMIT_REQUESTS_PER_MINUTE=60
